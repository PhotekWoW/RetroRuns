# Treat all text files with LF line endings in the repo; convert on
# checkout to the platform default. Prevents whole-file diffs caused
# by Windows / macOS / Linux line-ending mismatch.
* text=auto eol=lf

# Binary files: never touch
*.tga       binary
*.ttf       binary
*.TTF       binary
*.png       binary
*.jpg       binary
*.zip       binary
